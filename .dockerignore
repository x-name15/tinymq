# Ignore documentation and assets
docs/
README.md
images/
examples/
LICENSE
CHANGELOG.md

# Ignore GitHub Actions workflows
.github/

# Ignore the local data folder to avoid overwriting it
data/

# Ignore version control
.git/
.gitignore

# Ignore local binaries and CLI source (Docker only needs the broker)
bin/
cmd/tmq/
tmq
tmq.exe

# Ignore tests to keep the build context clean and optimize cache
internal/tests/
*_test.go