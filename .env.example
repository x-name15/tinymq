# 🍃 TinyMQ Configuration

# The port where the broker will listen
PORT=7800

# Strict Disk Durability. 
# Set to 'true' to force physical disk syncs after every operation (Bank-grade, but slower).
TINYMQ_FSYNC=false

# Auto-Compaction Interval (Garbage Collection). 
# How often the broker rewrites .log files to save disk space.
TINYMQ_COMPACT_INTERVAL=10m

# Default Queue Eviction Policy when capacity (100,000 msgs) is reached.
# Options: 
#   'reject'      -> Returns HTTP 429 / Error to publisher (Default).
#   'drop-oldest' -> Silently discards the oldest message to accept the new one (Ring Buffer mode).
TINYMQ_DEFAULT_POLICY=reject

# Maximum number of messages held in RAM per topic.
TINYMQ_MAX_MESSAGES=100000

# API Security Token.
# If set, all endpoints will require an 'Authorization: Bearer <token>' header.
# If left empty, the broker will run without authentication (Open access).
TINYMQ_API_KEY=value-here

# Per-IP HTTP rate limit for authenticated REST routes.
# Set to a positive number of requests per second, or leave empty/0 to disable.
TINYMQ_RATE_LIMIT=100

# Optional TLS certificate and key for HTTPS on the REST server.
# If both are set, the HTTP server starts in TLS mode; otherwise it stays on plain HTTP.
TINYMQ_TLS_CERT=
TINYMQ_TLS_KEY=

# Maximum number of unique topics/queues allowed in memory.
# Protects the broker against DoS attacks via unlimited queue creation.
TINYMQ_MAX_TOPICS=10000

# --- MQTTSETTINGS ---

# MQTT Protocol Port (Enables MQTT support on this port).
TINYMQ_MQTT_PORT=1883

# Set to 'true' to natively disable the MQTT server and save TCP resources
TINYMQ_MQTT_DISABLE=false

# --- CLUSTERING SETTINGS ---

# [SECURITY CRITICAL] Shared HMAC secret for TCP inter-node authentication.
# If empty, the cluster is OPEN and unauthenticated.
TINYMQ_CLUSTER_SECRET=super-secure-key-here

# Custom timeout for Quorum replication (Default: 500ms)
TINYMQ_CLUSTER_REPLICATE_TIMEOUT=500ms

# The TCP address where this node will listen for cluster connections (e.g., 127.0.0.1:7901 or node1:7900)
TINYMQ_CLUSTER_ADDR=

# Comma-separated list of other nodes in the cluster (e.g., 127.0.0.1:7902,127.0.0.1:7903)
TINYMQ_CLUSTER_NODES=

# Set to 'true' to force this node to be the static Leader (disables automatic elections)
TINYMQ_CLUSTER_LEADER=false

# The HTTP URL this node will advertise to followers for reverse proxying (e.g., 192.168.1.10:7800)
TINYMQ_CLUSTER_HTTP_ADVERTISE=

# --- NATS GATEWAY SETTINGS ---
# NATS-compatible TCP port. When set, TinyMQ speaks the NATS text protocol
# on this port, allowing any nats.py / nats.go / nats.js client to connect
# without a custom SDK. Leave empty to disable.
# Standard NATS port is 4222.
TINYMQ_NATS_PORT=